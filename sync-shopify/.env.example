# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shopify_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# Encryption
FERNET_KEY=your_fernet_key_here

# Shopify API Configuration
SHOPIFY_BATCH_SIZE=500
SHOPIFY_REQUEST_TIMEOUT=30

# Retry & Rate Limiting
MAX_RETRIES=3
INITIAL_BACKOFF=1.0
MAX_BACKOFF=60.0

# Logging
LOG_LEVEL=INFO
